---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const href = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
---

<nav class="sidebar">
  <div class="sidebar_content">
    <ul class="sidebar_menu">
      <li class="menu_item"><a href={href("/")} class={Astro.url.pathname === basePath || Astro.url.pathname === `${basePath}index.html` ? "active" : ""}>Home</a></li>
      <li class="menu_item"><a href={href("/about/")} class={Astro.url.pathname.includes(`${basePath}about`) ? "active" : ""}>About</a></li>
      <li class="menu_item"><a href={href("/journal/")} class={Astro.url.pathname.includes(`${basePath}journal`) ? "active" : ""}>Journal</a></li>
      <li class="menu_item"><a href={href("/gallery/")} class={Astro.url.pathname.includes(`${basePath}gallery`) ? "active" : ""}>Gallery</a></li>
      <li class="menu_item"><a href={href("/disco/")} class={Astro.url.pathname.includes(`${basePath}disco`) ? "active" : ""}>Discography</a></li>
      <li class="menu_item"><a href={href("/info/")} class={Astro.url.pathname.includes(`${basePath}info`) ? "active" : ""}>Information</a></li>
    </ul>
  </div>
</nav>
