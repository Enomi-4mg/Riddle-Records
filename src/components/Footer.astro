---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
---

<footer class="site-footer" style="text-align: center; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #ccc;">
  <p>&copy; {year} 4mg - Riddle Records</p>
  <p style="font-size: 0.9rem; color: #666;">Built with Astro and GitHub Pages</p>
  <p style="font-size: 0.7rem; opacity: 0.3; margin-top: 1rem;">
    <a href={`${basePath}legacy/index.html`} style="color: inherit; text-decoration: none;">·</a>
  </p>
</footer>
