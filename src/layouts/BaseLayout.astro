---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import mainStyles from "../../assets/css/main.css?url";
import animationsStyles from "../../assets/css/animations.css?url";
import galleryStyles from "../../assets/css/gallery.css?url";
import journalStyles from "../../assets/css/journal.css?url";
import faviconUrl from "../../favicon/favicon.ico?url";
import galleryScript from "../../assets/js/gallery.js?url";
import siteScript from "../../script.js?url";
const lightboxStyles = "https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/css/lightbox.min.css";
const lightboxScript = "https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox-plus-jquery.min.js";
const siteBase = import.meta.env.BASE_URL;
const basePath = siteBase.endsWith("/") ? siteBase : `${siteBase}/`;
const siteOrigin = Astro.site ?? Astro.url;

const resolveAssetUrl = (value) => {
  if (!value) {
    return new URL(`${basePath}favicon/icon.jpg`, siteOrigin).href;
  }

  if (/^https?:\/\//.test(value)) {
    return value;
  }

  const normalizedPath = value.startsWith("/") ? `${basePath}${value.replace(/^\/+/, "")}` : `${basePath}${value}`;
  return new URL(normalizedPath, siteOrigin).href;
};

const {
  title = "Riddle Records",
  description = "4mgのポートフォリオサイトです。",
  ogTitle = title,
  ogDescription = description,
  ogType = "website",
  ogImage,
  ogImageAlt = title,
  twitterCard = "summary_large_image",
  twitterSite = "@4mgEnomi",
  wideContainer = false
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname + Astro.url.search, siteOrigin).href;
const ogImageUrl = resolveAssetUrl(ogImage);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="Riddle Records" />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:site" content={twitterSite} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={faviconUrl} type="image/x-icon" />
    <link rel="stylesheet" href={mainStyles} />
    <link rel="stylesheet" href={animationsStyles} />
    <link rel="stylesheet" href={galleryStyles} />
    <link rel="stylesheet" href={journalStyles} />
    <link rel="stylesheet" href={lightboxStyles} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Kiwi+Maru&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
  </head>
  <body>
    <div class="transition-curtain initial"></div>
    <Header />
    <Sidebar />
    <main class={wideContainer ? "container wide-container" : "container"}>
      <slot />
    </main>
    <Footer />
    <script src={galleryScript}></script>
    <script src={siteScript}></script>
    <script defer src={lightboxScript}></script>
  </body>
</html>
