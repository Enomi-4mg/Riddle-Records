---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getGalleryItems, getSortedGalleryItems } from "../utils/gallery";
import { resolveImageUrl } from "../utils/images";
import { getJournalRoutePath, toJournalRoutePath } from "../utils/journal";

const base = import.meta.env.BASE_URL;
const cloudinaryBase = "https://res.cloudinary.com/dzq8y9qes/image/upload";
const basePath = base.endsWith("/") ? base : `${base}/`;
const href = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
const showDrafts = !import.meta.env.PROD;

const journals = (await getCollection("journal"))
  .filter((entry) => showDrafts || !entry.data.draft)
  .sort((left, right) => right.data.date.getTime() - left.data.date.getTime());
const songs = (await getCollection("songs")).sort((left, right) => right.data.date.getTime() - left.data.date.getTime());
const latestJournal = journals[0];
const latestSong = songs[0];
const galleryItems = await getGalleryItems();
const latestGallery = (await getSortedGalleryItems())[0];
const latestWorkDate = latestGallery && latestSong
  ? new Date(latestGallery.date).getTime() >= latestSong.data.date.getTime()
    ? latestGallery.date
    : latestSong.data.date.toISOString().slice(0, 10)
  : latestGallery?.date ?? latestSong?.data.date.toISOString().slice(0, 10);
const summarize = (text) => (text ? text.replace(/\s+/g, " ").trim().slice(0, 70) : "");
const getJournalSummary = (entry) => entry.data.description ?? entry.data.og_description ?? entry.body;
const getJournalThumbnail = (entry) => {
  const explicitThumbnail = resolveImageUrl(entry.data.thumbnail, "w_400,h_400,c_fill,q_auto,f_auto");
  if (explicitThumbnail) {
    return {
      src: explicitThumbnail,
      alt: entry.data.thumbnail_alt ?? entry.data.title
    };
  }

  const journalPath = getJournalRoutePath(entry);
  const galleryThumbnail = galleryItems.find((item) => {
    if (item.thumbnail === false) {
      return false;
    }

    return (
      (item.article_url && toJournalRoutePath(item.article_url) === journalPath) ||
      (item.making_article_url && toJournalRoutePath(item.making_article_url) === journalPath)
    );
  });

  if (galleryThumbnail) {
    return {
      src: `${cloudinaryBase}/w_400,h_400,c_fill,q_auto,f_auto/v1/${galleryThumbnail.image}`,
      alt: galleryThumbnail.imageAlt
    };
  }

  const legacyImage = resolveImageUrl(entry.data.image, "w_400,h_400,c_fill,q_auto,f_auto");
  if (legacyImage) {
    return {
      src: legacyImage,
      alt: entry.data.thumbnail_alt ?? entry.data.title
    };
  }

  return null;
};
---

<BaseLayout title="Riddle Records" description="4mgのポートフォリオサイトです。">
  <section class="home-intro journal-entry-animate">
    <h1 class="home-welcome">ようこそ！<br />Riddle Records 公式サイトへ。</h1>
    <p>4mgのポートフォリオサイトです。</p>
    <p>ページ上部のヘッダーメニューからも各ページへ移動できます。</p>
    <p><small>最終更新：{new Date().toLocaleDateString("ja-JP")}</small></p>
  </section>

  <section class="home-latest journal-entry-animate">
    <h2 class="page_title">コンテンツ</h2>
    <div class="home-grid">
      <a href={href("/about/")} class="home-card home-card-link journal-entry-animate">
        <div class="home-card-head">
          <span class="home-card-label">About</span>
        </div>
        <h3 class="home-card-title">プロフィール</h3>
        <p class="home-card-desc">プロフィールとリンク集を掲載しています。</p>
        <span class="home-card-cta">About を見る →</span>
      </a>

      {latestJournal && (
        <article class="home-card journal-entry-animate">
          {(() => {
            const journalThumbnail = getJournalThumbnail(latestJournal);
            return (
              <a href={href(`/journal/${getJournalRoutePath(latestJournal)}/`)} class="home-card-clickable">
            <div class="home-card-head">
              <span class="home-card-label">Journal</span>
              <time class="home-card-date" datetime={latestJournal.data.date.toISOString().slice(0, 10)}>{latestJournal.data.date.toLocaleDateString("ja-JP")}</time>
            </div>
            {journalThumbnail && (
              <div class="home-card-thumb">
                <img src={journalThumbnail.src} alt={journalThumbnail.alt} loading="lazy" />
              </div>
            )}
            <h3 class="home-card-title">{latestJournal.data.title}</h3>
            <p class="home-card-desc">{summarize(getJournalSummary(latestJournal))}</p>
              </a>
            );
          })()}
          <a class="home-card-cta" href={href("/journal/")}>一覧を見る →</a>
        </article>
      )}

      {(latestGallery || latestSong) && (
        <article class="home-card journal-entry-animate">
          <a href={href("/works/")} class="home-card-clickable">
            <div class="home-card-head">
              <span class="home-card-label">Works</span>
              {latestWorkDate && <time class="home-card-date" datetime={latestWorkDate}>{new Date(latestWorkDate).toLocaleDateString("ja-JP")}</time>}
            </div>
            {latestGallery && (
              <div class="home-card-thumb">
                <img src={`https://res.cloudinary.com/dzq8y9qes/image/upload/w_400,h_400,c_fill,q_auto,f_auto/v1/${latestGallery.image}`} alt={latestGallery.imageAlt} loading="lazy" />
              </div>
            )}
            <h3 class="home-card-title">作品一覧</h3>
            <p class="home-card-desc">
              {latestGallery && latestSong
                ? `${latestGallery.title} や ${latestSong.data.title} など、作品と楽曲をまとめています。`
                : "Gallery作品と楽曲をまとめています。"}
            </p>
          </a>
          <a class="home-card-cta" href={href("/works/")}>Works を見る →</a>
        </article>
      )}

      <a href={href("/project/")} class="home-card home-card-link journal-entry-animate">
        <div class="home-card-head">
          <span class="home-card-label">Project</span>
        </div>
        <h3 class="home-card-title">制作プロジェクト</h3>
        <p class="home-card-desc">アプリ、Web作品、実験的なプロジェクトをまとめています。</p>
        <span class="home-card-cta">Project を見る →</span>
      </a>

      <a href={href("/info/")} class="home-card home-card-link journal-entry-animate">
        <div class="home-card-head">
          <span class="home-card-label">Information</span>
        </div>
        <h3 class="home-card-title">お知らせ</h3>
        <p class="home-card-desc">最新のお知らせや更新情報はこちらをご確認ください。</p>
        <span class="home-card-cta">一覧を見る →</span>
      </a>
    </div>
  </section>
</BaseLayout>
