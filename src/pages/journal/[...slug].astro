---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { resolveImageUrl } from "../../utils/images";
import { getJournalRoutePath } from "../../utils/journal";

const base = import.meta.env.BASE_URL;
const showDrafts = !import.meta.env.PROD;
const journalEntries = (await getCollection("journal"))
  .filter((entry) => showDrafts || !entry.data.draft)
  .sort((left, right) => right.data.date.getTime() - left.data.date.getTime());

const formatDate = (date) => `${date.getFullYear()}年${String(date.getMonth() + 1).padStart(2, "0")}月${String(date.getDate()).padStart(2, "0")}日`;
const basePath = base.endsWith("/") ? base : `${base}/`;
const withBase = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
const normalizeCredits = (credits) => Array.isArray(credits) ? credits.join("\n") : credits;

export async function getStaticPaths() {
  const showDraftPaths = !import.meta.env.PROD;
  const journalEntriesForPaths = (await getCollection("journal")).filter((entry) => showDraftPaths || !entry.data.draft);
  return journalEntriesForPaths.map((entry) => ({
    params: {
      slug: getJournalRoutePath(entry)
    },
    props: {
      entry
    }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const entryDate = formatDate(entry.data.date);
const summary = entry.data.description ?? entry.data.og_description ?? entry.data.title;
const ogImage = resolveImageUrl(entry.data.og_image ?? entry.data.image ?? entry.data.thumbnail, "w_1200,h_630,c_fill,q_auto,f_auto");
const currentIndex = journalEntries.findIndex((candidate) => candidate.id === entry.id);
const newerEntry = currentIndex > 0 ? journalEntries[currentIndex - 1] : null;
const olderEntry = currentIndex >= 0 && currentIndex < journalEntries.length - 1 ? journalEntries[currentIndex + 1] : null;
---

<BaseLayout
  title={entry.data.title}
  description={summary}
  ogTitle={entry.data.title}
  ogDescription={summary}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={entry.data.thumbnail_alt ?? entry.data.title}
>
  <article class="post journal-article" data-use-math={entry.data.use_math ? "true" : undefined}>
    <div class="journal-back-link journal-back-link-top">
      <a href={withBase("/journal/")}>Journal一覧へ戻る</a>
    </div>

    <header class="journal-hero">
      <p class="journal-date">
        <time datetime={entry.data.date.toISOString().slice(0, 10)}>{entryDate}</time>
      </p>
      <h1 class="page_title">{entry.data.title}</h1>
      {summary && <p class="journal-summary">{summary}</p>}
    </header>

    <div class="post-content journal-content">
      <Content />
    </div>

    {entry.data.credits && (
      <section class="post-info">
        <div class="post-credits">
          <h3>クレジット</h3>
          <pre>{normalizeCredits(entry.data.credits)}</pre>
        </div>
      </section>
    )}

    {entry.data.lyrics && (
      <section class="post-lyrics">
        <details id="lyrics-details">
          <summary>歌詞</summary>
          <pre>{entry.data.lyrics}</pre>
        </details>
      </section>
    )}

    <div class="journal-back-link">
      <a href={withBase("/journal/")}>Journal一覧へ戻る</a>
    </div>

    <nav class="post-nav">
      {olderEntry && (
        <a href={withBase(`/journal/${getJournalRoutePath(olderEntry)}/`)} class="post-nav-prev">← {olderEntry.data.title}</a>
      )}

      {newerEntry && (
        <a href={withBase(`/journal/${getJournalRoutePath(newerEntry)}/`)} class="post-nav-next">{newerEntry.data.title} →</a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .journal-article {
    max-width: 900px;
    margin: 0 auto;
  }

  .journal-hero {
    margin-bottom: 1.5rem;
    padding: clamp(1.25rem, 3vw, 2rem) clamp(1rem, 4vw, 2rem);
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(20, 40, 30, 0.08);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 28px rgba(10, 21, 16, 0.05);
  }

  .journal-date {
    margin-bottom: 0.5rem;
    color: rgba(20, 40, 30, 0.72);
    font-size: 0.82rem;
  }

  .journal-hero .page_title {
    margin: 0;
    padding: 0;
    max-width: none;
    font-size: clamp(2.15rem, 5.4vw, 4.25rem);
    line-height: 1.1;
    text-shadow: none;
  }

  .journal-summary {
    color: rgba(20, 40, 30, 0.85);
    font-size: 1rem;
    line-height: 1.75;
  }

  .journal-content {
    display: grid;
    gap: 0.5rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(20, 40, 30, 0.08);
    border-radius: var(--radius-lg);
    box-shadow: 0 14px 34px rgba(10, 21, 16, 0.06);
  }

  .journal-content :global(*) {
    letter-spacing: 0;
  }

  .journal-content :global(p),
  .journal-content :global(li) {
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.75;
  }

  .journal-content :global(p) {
    margin: 0;
  }

  .journal-content :global(h2),
  .journal-content :global(h3),
  .journal-content :global(h4) {
    color: #06110d;
    line-height: 1.45;
  }

  .journal-content :global(h2) {
    margin: 1.5rem 0 0;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(27, 180, 142, 0.24);
    font-size: clamp(1.45rem, 3vw, 2.3rem);
  }

  .journal-content :global(h2:first-child) {
    margin-top: 0;
  }

  .journal-content :global(h3) {
    margin: 1rem 0 0;
    color: #1a5f4e;
    font-size: 1.18rem;
  }

  .journal-content :global(h4) {
    margin: 1rem 0 0;
    font-size: 1.04rem;
  }

  .journal-content :global(ul),
  .journal-content :global(ol) {
    margin: 0;
    padding-left: 1.25rem;
  }

  .journal-content :global(blockquote) {
    margin: 1.6rem 0;
    padding: 1rem 1.25rem;
    background: rgba(244, 255, 250, 0.82);
    border-left: 4px solid var(--color-mint-deep);
    border-radius: var(--radius-sm);
  }

  .journal-content :global(.responsive-video-container) {
    position: relative;
    width: 100%;
    max-width: 900px;
    margin: 2rem auto;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #000;
  }

  .journal-content :global(.responsive-video-container iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .post-info {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(20, 40, 30, 0.08);
  }

  .post-info {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .post-credits,
  .post-lyrics {
    padding: 1.5rem;
    border-radius: 0.5rem;
  }

  .post-credits h2 {
    margin-top: 0;
  }

  .post-credits h3 {
    margin-top: 0;
    color: #1bb48e;
    font-size: 1.2rem;
  }

  .post-credits {
    background-color: rgba(27, 180, 142, 0.1);
    border-left: 4px solid #1bb48e;
  }

  .post-lyrics details {
    cursor: pointer;
  }

  .post-lyrics summary {
    font-size: 1.2rem;
    font-weight: bold;
    color: #0a1510;
    user-select: none;
  }

  .post-lyrics {
    margin-top: 0;
    padding: 1.5rem;
    background-color: #f9f9f9;
    border: 1px solid #ddd;
  }

  .post-lyrics summary {
    padding: 0.5rem;
    margin: -0.5rem -0.5rem 0 -0.5rem;
    transition: background-color 0.2s ease;
  }

  .post-lyrics summary:hover {
    background-color: rgba(27, 180, 142, 0.1);
    border-radius: 0.3rem;
  }

  .post-lyrics pre {
    margin: 1rem 0 0 0;
    padding: 1rem;
    background-color: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 0.3rem;
    white-space: pre-wrap;
  }

  .post-info pre {
    white-space: pre-wrap;
  }

  .journal-back-link {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(20, 40, 30, 0.08);
  }

  .journal-back-link-top {
    margin: 0 0 1rem;
    padding-top: 0;
    border-top: 0;
  }

  .journal-back-link a {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0.45rem 0.85rem;
    color: var(--color-ink);
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(20, 40, 30, 0.1);
    border-radius: var(--radius-md);
    text-decoration: none;
    box-shadow: 0 8px 20px rgba(10, 21, 16, 0.04);
  }

  .journal-back-link a::before {
    content: "←";
    margin-right: 0.45rem;
    color: var(--color-mint-deep);
  }

  .journal-back-link a:hover {
    background: rgba(42, 220, 163, 0.13);
    border-color: rgba(27, 180, 142, 0.26);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(20, 40, 30, 0.12);
    flex-wrap: wrap;
  }

  .post-nav a {
    color: #1bb48e;
    text-decoration: none;
  }

  .post-nav a:hover {
    text-decoration: underline;
  }

  .journal-content :global(.gallery-link-btn) {
    margin-top: 0.8rem;
  }

  .journal-content :global(img) {
    max-width: 100%;
  }

  @media screen and (max-width: 600px) {
    .journal-hero,
    .journal-content {
      border-radius: var(--radius-md);
    }

    .journal-content {
      padding: 1.2rem;
    }

    .journal-content :global(p),
    .journal-content :global(li) {
      font-size: 1.04rem;
      line-height: 1.75;
    }

    .post-info {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
