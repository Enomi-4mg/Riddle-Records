---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { resolveImageUrl } from "../../utils/images";
import { getJournalRoutePath } from "../../utils/journal";

const base = import.meta.env.BASE_URL;
const showDrafts = !import.meta.env.PROD;
const journalEntries = (await getCollection("journal"))
  .filter((entry) => showDrafts || !entry.data.draft)
  .sort((left, right) => right.data.date.getTime() - left.data.date.getTime());

const formatDate = (date) => `${date.getFullYear()}年${String(date.getMonth() + 1).padStart(2, "0")}月${String(date.getDate()).padStart(2, "0")}日`;
const basePath = base.endsWith("/") ? base : `${base}/`;
const withBase = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
const normalizeCredits = (credits) => Array.isArray(credits) ? credits.join("\n") : credits;

export async function getStaticPaths() {
  const showDraftPaths = !import.meta.env.PROD;
  const journalEntriesForPaths = (await getCollection("journal")).filter((entry) => showDraftPaths || !entry.data.draft);
  return journalEntriesForPaths.map((entry) => ({
    params: {
      slug: getJournalRoutePath(entry)
    },
    props: {
      entry
    }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const entryDate = formatDate(entry.data.date);
const summary = entry.data.description ?? entry.data.og_description ?? entry.data.title;
const ogImage = resolveImageUrl(entry.data.og_image ?? entry.data.image ?? entry.data.thumbnail, "w_1200,h_630,c_fill,q_auto,f_auto");
const currentIndex = journalEntries.findIndex((candidate) => candidate.id === entry.id);
const newerEntry = currentIndex > 0 ? journalEntries[currentIndex - 1] : null;
const olderEntry = currentIndex >= 0 && currentIndex < journalEntries.length - 1 ? journalEntries[currentIndex + 1] : null;
---

<BaseLayout
  title={entry.data.title}
  description={summary}
  ogTitle={entry.data.title}
  ogDescription={summary}
  ogType="article"
  ogImage={ogImage}
  ogImageAlt={entry.data.thumbnail_alt ?? entry.data.title}
>
  <article class="post journal-article" data-use-math={entry.data.use_math ? "true" : undefined}>
    <div class="journal-back-link journal-back-link-top">
      <a href={withBase("/journal/")}>Journal一覧へ戻る</a>
    </div>

    <header class="journal-hero">
      <p class="journal-date">
        <time datetime={entry.data.date.toISOString().slice(0, 10)}>{entryDate}</time>
      </p>
      <h1 class="page_title">{entry.data.title}</h1>
      {summary && <p class="journal-summary">{summary}</p>}
    </header>

    <div class="post-content journal-content">
      <Content />
    </div>

    {entry.data.credits && (
      <section class="post-info">
        <div class="post-credits">
          <h3>クレジット</h3>
          <pre>{normalizeCredits(entry.data.credits)}</pre>
        </div>
      </section>
    )}

    {entry.data.lyrics && (
      <section class="post-lyrics">
        <details id="lyrics-details">
          <summary>歌詞</summary>
          <pre>{entry.data.lyrics}</pre>
        </details>
      </section>
    )}

    <div class="journal-back-link">
      <a href={withBase("/journal/")}>Journal一覧へ戻る</a>
    </div>

    <nav class="post-nav">
      {olderEntry && (
        <a href={withBase(`/journal/${getJournalRoutePath(olderEntry)}/`)} class="post-nav-prev">← {olderEntry.data.title}</a>
      )}

      {newerEntry && (
        <a href={withBase(`/journal/${getJournalRoutePath(newerEntry)}/`)} class="post-nav-next">{newerEntry.data.title} →</a>
      )}
    </nav>
  </article>
</BaseLayout>
