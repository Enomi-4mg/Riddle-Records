---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { galleryItems } from "../../data/gallery";
import fallbackIconUrl from "../../../favicon/icon.jpg?url";

const base = import.meta.env.BASE_URL;
const cloudinaryBase = "https://res.cloudinary.com/dzq8y9qes/image/upload";
const journalEntries = (await getCollection("journal")).sort((left, right) => right.data.date.getTime() - left.data.date.getTime());

const formatDate = (date) => `${date.getFullYear()}年${String(date.getMonth() + 1).padStart(2, "0")}月${String(date.getDate()).padStart(2, "0")}日`;
const toRoutePath = (path) => path.replace(/^\/+/, "").replace(/\/+$/, "").replace(/^journal\//, "");
const basePath = base.endsWith("/") ? base : `${base}/`;
const withBase = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
const getJournalPath = (entry) => toRoutePath(entry.data.permalink ?? `/journal/${entry.data.date.toISOString().slice(0, 10)}/`);
const getJournalUrl = (entry) => withBase(`/journal/${getJournalPath(entry)}/`);
const getThumbnail = (entry) => {
  const journalPath = getJournalPath(entry);
  if (entry.data.thumbnail_class) {
    const byClass = galleryItems.find((item) => item.thumbnail_class === entry.data.thumbnail_class && item.thumbnail !== false);
    if (byClass) {
      return byClass;
    }
  }

  return galleryItems.find((item) => {
    if (item.thumbnail === false) {
      return false;
    }

    return (
      (item.article_url && toRoutePath(item.article_url) === journalPath) ||
      (item.making_article_url && toRoutePath(item.making_article_url) === journalPath)
    );
  }) ?? null;
};
---

<BaseLayout title="Journal" description="日記・活動報告の一覧。" wideContainer={true}>
  <h1 class="web_title">Journal</h1>

  <div style="max-width: 900px; margin: 0 auto; padding: 0 1rem;">
    {journalEntries.map((entry) => {
      const thumbnail = getThumbnail(entry);
      const articleUrl = getJournalUrl(entry);
      return (
        <div class="journal-entry-animate" style="display: flex; gap: 1.5rem; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid #e0e0e0;">
          <a href={articleUrl} style="flex-shrink: 0;">
            <img
              src={thumbnail ? `${cloudinaryBase}/w_400,h_400,c_fill,q_auto,f_auto/v1/${thumbnail.cloudinary_id}` : fallbackIconUrl}
              alt={thumbnail ? thumbnail.title : entry.data.title}
              style="width: 160px; height: 130px; object-fit: cover; border-radius: 4px;"
              loading="lazy"
            />
          </a>
          <div style="flex: 1;">
            <h3 style="margin: 0 0 0.5rem 0; font-size: 1.5rem;"><a href={articleUrl}>{entry.data.title}</a></h3>
            <div style="color: #666; font-size: 1.1rem; margin-bottom: 0.7rem;">{formatDate(entry.data.date)}</div>
            <p style="margin: 0; color: #555; font-size: 1.15rem; line-height: 1.6;">{entry.data.og_description ?? ""}</p>
          </div>
        </div>
      );
    })}
  </div>
</BaseLayout>
