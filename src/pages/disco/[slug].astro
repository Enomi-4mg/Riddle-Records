---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const withBase = (path) => `${basePath}${path.replace(/^\/+/, "")}`;

export async function getStaticPaths() {
  const songs = await getCollection("songs");
  return songs.map((song) => ({
    params: {
      slug: song.slug
    },
    props: {
      song
    }
  }));
}

const { song } = Astro.props;
const { Content } = await render(song);
const credits = Array.isArray(song.data.credits) ? song.data.credits.join("\n") : song.data.credits;
const entryDateIso = song.id.split("/").pop()?.replace(/\.md$/, "") ?? song.data.date.toISOString().slice(0, 10);
---

<BaseLayout
  title={song.data.title}
  description={song.data.description ?? song.data.title}
  ogTitle={song.data.title}
  ogDescription={song.data.description ?? song.data.title}
  ogType="article"
  ogImage={`https://img.youtube.com/vi/${song.data.youtube_id}/maxresdefault.jpg`}
  ogImageAlt={song.data.title}
>
  <article class="post song-article">
    <header class="song-hero">
      <time class="post-date" datetime={entryDateIso}>
        {song.data.date.getFullYear()}年{String(song.data.date.getMonth() + 1).padStart(2, "0")}月{String(song.data.date.getDate()).padStart(2, "0")}日
      </time>
      <h1 class="page_title">{song.data.title}</h1>
      {song.data.description && <p>{song.data.description}</p>}
    </header>

    <div class="song-video responsive-video-container">
      <iframe
        width="560"
        height="315"
        src={`https://www.youtube.com/embed/${song.data.youtube_id}`}
        title={song.data.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>

    <div class="post-content song-content">
      <Content />
    </div>

    {credits && (
      <section class="post-info song-meta">
        <div class="post-credits">
          <h3>クレジット</h3>
          <pre>{credits}</pre>
        </div>
      </section>
    )}

    {song.data.lyrics && (
      <section class="post-lyrics">
        <details id="lyrics-details">
          <summary>歌詞</summary>
          <pre>{song.data.lyrics}</pre>
        </details>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .song-article {
    max-width: 900px;
    margin: 0 auto;
  }

  .song-hero {
    margin-bottom: 1.5rem;
  }

  .post-date {
    display: inline-block;
    margin-bottom: 0.5rem;
    color: rgba(20, 40, 30, 0.72);
  }

  .song-video {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    margin: 1.5rem 0;
    overflow: hidden;
    background: #000;
    border-radius: 1rem;
  }

  .song-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .song-meta {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(20, 40, 30, 0.08);
  }

  .post-credits,
  .post-lyrics {
    padding: 1.5rem;
    border-radius: 0.5rem;
  }

  .post-lyrics details {
    cursor: pointer;
  }

  .post-lyrics summary {
    font-size: 1.2rem;
    font-weight: bold;
    color: #0a1510;
    user-select: none;
    padding: 0.5rem;
    margin: -0.5rem -0.5rem 0 -0.5rem;
    transition: background-color 0.2s ease;
  }

  .post-lyrics summary:hover {
    background-color: rgba(27, 180, 142, 0.1);
    border-radius: 0.3rem;
  }

  .post-credits {
    background-color: rgba(27, 180, 142, 0.1);
    border-left: 4px solid #1bb48e;
  }

  .post-credits h3 {
    margin-top: 0;
    color: #1bb48e;
    font-size: 1.2rem;
  }

  .post-credits pre {
    margin: 0.5rem 0 0;
    padding: 0.75rem;
    background-color: transparent;
    border: none;
    font-family: inherit;
    font-size: 20px;
    line-height: 1.6;
    color: #333;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .post-lyrics {
    margin-top: 2rem;
    background-color: #f9f9f9;
    border: 1px solid #ddd;
  }

  .post-lyrics pre {
    margin: 1rem 0 0 0;
    padding: 1rem;
    background-color: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 0.3rem;
    white-space: pre-wrap;
  }

  .song-meta pre {
    white-space: pre-wrap;
  }

  .song-content :global(iframe) {
    max-width: 100%;
  }
</style>
