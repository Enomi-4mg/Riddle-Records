---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const songs = (await getCollection("songs")).sort((left, right) => {
  const dateDiff = right.data.date.getTime() - left.data.date.getTime();
  if (dateDiff !== 0) return dateDiff;
  return right.id.localeCompare(left.id);
});
const formatDate = (date) => `${date.getFullYear()}年${String(date.getMonth() + 1).padStart(2, "0")}月${String(date.getDate()).padStart(2, "0")}日`;
const getEntryDateIso = (entry) => entry.id.split("/").pop()?.replace(/\.md$/, "") ?? entry.data.date.toISOString().slice(0, 10);
const basePath = base.endsWith("/") ? base : `${base}/`;
const withBase = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
---

<BaseLayout title="Discography" description="公開した楽曲の一覧。">
  <section class="page-header">
    <h1>Discography</h1>
    <p>公開した楽曲の一覧です。</p>
  </section>

  <div class="works-grid works-grid-list">
    {songs.map((song) => (
      <article class="work-card work-card-unified">
        <a href={withBase(`/disco/${song.slug}/`)} class="work-thumb">
          <img src={`https://img.youtube.com/vi/${song.data.youtube_id}/sddefault.jpg`} alt={song.data.title} loading="lazy" />
        </a>
        <div class="work-copy">
          <h2 class="work-title"><a href={withBase(`/disco/${song.slug}/`)}>{song.data.title}</a></h2>
          <time class="work-date" datetime={getEntryDateIso(song)}>{formatDate(song.data.date)}</time>
          <p class="work-desc">{song.data.description ?? ""}</p>
          <div class="work-tags" aria-label={`${song.data.title} tags`}>
            <span class="work-tag">Music</span>
            {(song.data.tags ?? []).map((tag) => <span class="work-tag">{tag}</span>)}
          </div>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
