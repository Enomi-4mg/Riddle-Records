---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const songs = (await getCollection("songs")).sort((left, right) => {
  const dateDiff = right.data.date.getTime() - left.data.date.getTime();
  if (dateDiff !== 0) return dateDiff;
  return right.id.localeCompare(left.id);
});
const formatDate = (date) => `${date.getFullYear()}年${String(date.getMonth() + 1).padStart(2, "0")}月${String(date.getDate()).padStart(2, "0")}日`;
const getEntryDateIso = (entry) => entry.id.split("/").pop()?.replace(/\.md$/, "") ?? entry.data.date.toISOString().slice(0, 10);
const basePath = base.endsWith("/") ? base : `${base}/`;
const withBase = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
---

<BaseLayout title="Discography" description="公開した楽曲の一覧。">
  <section class="page-header">
    <h1>Discography</h1>
    <p>公開した楽曲の一覧です。</p>
  </section>

  <div class="song-grid">
    {songs.map((song) => (
      <article class="song-card">
        <a href={withBase(`/disco/${song.slug}/`)} class="song-thumb-link">
          <img src={`https://img.youtube.com/vi/${song.data.youtube_id}/sddefault.jpg`} alt={song.data.title} loading="lazy" />
        </a>
        <div class="song-copy">
          <h2><a href={withBase(`/disco/${song.slug}/`)}>{song.data.title}</a></h2>
          <time datetime={getEntryDateIso(song)}>{formatDate(song.data.date)}</time>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .song-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .song-card {
    overflow: hidden;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(20, 40, 30, 0.08);
  }

  .song-card img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .song-copy {
    padding: 1rem;
  }

  .song-copy h2 {
    margin-bottom: 0.5rem;
  }

  .song-copy a {
    text-decoration: none;
  }
</style>
