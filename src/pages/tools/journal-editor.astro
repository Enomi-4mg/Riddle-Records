    --editor-accent: #168a73;
    --editor-accent-dark: #0f6f5c;
    --editor-soft: rgba(42, 220, 163, 0.1);
    max-width: 1680px;
    margin: 0 auto;
    padding: 0 clamp(0.75rem, 1.6vw, 1.5rem) 3rem;
