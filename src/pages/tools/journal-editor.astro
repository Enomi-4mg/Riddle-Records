    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(420px, 1.25fr) minmax(360px, 0.95fr);
    gap: clamp(1rem, 1.6vw, 1.35rem);
    align-items: start;
  }

  .editor-main {
    display: contents;
  }

  .editor-column {
    display: grid;
    gap: 1.15rem;
    align-content: start;
  }

  .editor-side {
    position: sticky;
    top: 80px;
  }

  .editor-panel {
    padding: clamp(1rem, 1.5vw, 1.25rem);
    border: 1px solid var(--editor-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 10px 30px rgba(18, 32, 25, 0.06);
  }

