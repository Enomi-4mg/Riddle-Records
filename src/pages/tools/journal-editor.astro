---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { galleryItems } from "../../data/gallery";

const today = new Date().toISOString().slice(0, 10);
const cloudinaryBase = "https://res.cloudinary.com/dzq8y9qes/image/upload";
const galleryIds = galleryItems.map((item) => item.cloudinary_id);
---

<BaseLayout title="Journal Editor" description="Riddle Records のJournal記事作成ツール。" wideContainer={true}>
  <section class="journal-editor" data-cloudinary-base={cloudinaryBase}>
    <header class="editor-header">
      <p class="editor-kicker">Riddle Records CMS</p>
      <h1 class="web_title">Journal Editor</h1>
    </header>

    <div class="top-actions">
      <div class="action-group primary-actions" aria-label="主要操作">
        <button type="button" class="primary-button" data-action="copy-content">記事全体をコピー</button>
        <button type="button" class="primary-button secondary-primary" data-action="download-content">Markdownをダウンロード</button>
      </div>
      <div class="action-group support-actions" aria-label="補助操作">
        <button type="button" data-action="copy-frontmatter">frontmatterのみコピー</button>
        <button type="button" data-action="copy-body">本文のみコピー</button>
        <button type="button" data-action="copy-gallery">Galleryコードをコピー</button>
      </div>
      <div class="action-group danger-actions" aria-label="危険操作">
        <button type="button" data-action="clear-draft">下書きを削除</button>
        <button type="button" data-action="reset-form">初期化</button>
      </div>
      <span class="draft-status" id="draft-status" aria-live="polite"></span>
    </div>

    <div class="editor-grid">
      <form class="editor-main" id="journal-form">
        <div class="editor-column editor-column-left">
        <section class="editor-panel">
          <div class="panel-heading">
            <div>
              <p class="section-label">Basic</p>
              <h2>基本情報</h2>
            </div>
          </div>

          <div class="field-row">
            <label>
              <span>テンプレート</span>
              <select id="template">
                <option value="journal">通常Journal</option>
                <option value="making">制作メモ</option>
                <option value="report">月次報告</option>
              </select>
            </label>
            <label>
              <span>日付</span>
              <input type="date" id="date" value={today} />
            </label>
          </div>

          <label>
            <span>タイトル</span>
            <input type="text" id="title" placeholder="記事タイトル" />
          </label>

          <div class="field-row">
            <label>
              <span>slug</span>
              <input type="text" id="slug" placeholder="makingでは推奨: dunes-making" />
            </label>
            <label>
              <span>推奨Markdownファイル名</span>
              <input type="text" id="filename" readonly />
            </label>
          </div>

          <label>
            <span>公開URL permalink（自動生成・必要時のみoverride）</span>
            <input type="text" id="permalink" placeholder="/journal/2026-04-30/sample/" />
          </label>

          <div class="generated-url-panel" id="url-status" aria-live="polite"></div>
        </section>

        <section class="editor-panel">
          <div class="panel-heading">
            <div>
              <p class="section-label">Publish</p>
              <h2>公開設定</h2>
            </div>
          </div>

          <label>
            <span>description</span>
            <textarea id="og-description" rows="3" placeholder="一覧・記事概要・OGPに使う短い説明"></textarea>
          </label>

          <div class="field-row">
            <label>
              <span>thumbnail</span>
              <input type="text" id="thumbnail" list="gallery-id-list" placeholder="一覧サムネ用 Cloudinary ID / URL / /local/path" />
            </label>
            <label>
              <span>thumbnail_alt</span>
              <input type="text" id="thumbnail-alt" placeholder="サムネイル画像の説明" />
            </label>
          </div>

          <details class="utility-details" open>
            <summary>サムネイル表示オプション</summary>
            <div class="field-row">
              <label>
                <span>thumbnail_fit</span>
                <input type="text" id="thumbnail-fit" placeholder="cover / contain など" />
              </label>
              <label>
                <span>thumbnail_position</span>
                <input type="text" id="thumbnail-position" placeholder="center / top など" />
              </label>
            </div>
          </details>

          <label>
            <span>og_image</span>
            <input type="text" id="og-image" list="gallery-id-list" placeholder="OGP用 Cloudinary ID / URL / /local/path" />
          </label>

          <div class="field-row">
            <label>
              <span>tags</span>
              <input type="text" id="tags" placeholder="日記, 3DCG, 制作" />
            </label>
            <label>
              <span>featured_related</span>
              <input type="text" id="featured-related" list="gallery-id-list" placeholder="Cloudinary IDをカンマ区切り" />
            </label>
          </div>

          <div class="switch-row">
            <label class="checkbox-field">
              <input type="checkbox" id="draft" />
              <span>draft</span>
            </label>
            <label class="checkbox-field">
              <input type="checkbox" id="use-math" />
              <span>数式を使う</span>
            </label>
          </div>

          <div class="media-resolve-panel" id="media-status" aria-live="polite"></div>

          <details class="utility-details">
            <summary>詳細設定</summary>
            <label>
              <span>thumbnail_class</span>
              <input type="text" id="thumbnail-class" placeholder="任意" />
            </label>
          </details>
        </section>
        </div>

        <div class="editor-column editor-column-center">
        <section class="editor-panel">
          <div class="panel-heading">
            <div>
              <p class="section-label">Content</p>
              <h2>本文</h2>
            </div>
          </div>

          <label>
            <span>本文 Markdown</span>
            <textarea id="body" class="body-editor" spellcheck="false"></textarea>
          </label>
        </section>

        <section class="editor-panel">
          <div class="panel-heading">
            <div>
              <p class="section-label">Media</p>
              <h2>画像カード</h2>
            </div>
            <span class="pill" id="card-count">0 cards</span>
          </div>

          <div class="field-row">
            <label>
              <span>カードレイアウト</span>
              <select id="card-layout">
                <option value="journal-card-grid">journal-card-grid</option>
                <option value="making-comparison-grid">making-comparison-grid</option>
              </select>
            </label>
            <label>
              <span>Lightbox group</span>
              <select id="lightbox-preset">
                <option value="Journal">Journal</option>
                <option value="gallery">gallery</option>
                <option value="making-comparison">making-comparison</option>
                <option value="custom">カスタム</option>
              </select>
            </label>
          </div>

          <label class="conditional-field" id="custom-lightbox-row" hidden>
            <span>カスタムLightbox group</span>
            <input type="text" id="custom-lightbox" placeholder="custom-group" />
          </label>

          <div class="card-list" id="card-list"></div>

          <div class="editor-actions">
            <button type="button" data-action="add-card">カードを追加</button>
            <button type="button" data-action="insert-cards">本文にカードHTMLを挿入</button>
            <button type="button" data-action="append-featured">featured_relatedに追加</button>
          </div>

          <details class="utility-details">
            <summary>記事本文からカードを解析</summary>
            <label>
              <span>既存記事のHTML/Markdown</span>
              <textarea id="article-input" class="article-analyzer" placeholder="<div class=&quot;journal-card&quot;>..."></textarea>
            </label>
            <div class="editor-actions">
              <button type="button" data-action="analyze-article">本文からカードを抽出</button>
              <button type="button" data-action="reset-cards">カードを初期化</button>
            </div>
          </details>
        </section>
        </div>
      </form>

      <aside class="editor-side">
        <section class="editor-panel side-panel">
          <div class="panel-heading">
            <div>
              <p class="section-label">Review</p>
              <h2>確認</h2>
            </div>
          </div>

          <div class="side-tabs" role="tablist" aria-label="確認パネル">
            <button type="button" class="tab-button is-active" data-tab="preview">プレビュー</button>
            <button type="button" class="tab-button" data-tab="checklist">公開前チェック</button>
            <button type="button" class="tab-button" data-tab="outputs">出力</button>
          </div>

          <div class="tab-panel is-active" data-panel="preview">
            <article id="preview" class="preview"></article>
          </div>

          <div class="tab-panel" data-panel="checklist">
            <ul class="publish-checklist" id="publish-checklist"></ul>
          </div>

          <div class="tab-panel" data-panel="outputs">
            <label>
              <span>Markdown</span>
              <textarea id="output-content" class="output-editor" readonly spellcheck="false"></textarea>
            </label>
            <label>
              <span>Galleryコード</span>
              <textarea id="gallery-output" class="output-editor compact-output" readonly spellcheck="false"></textarea>
            </label>
          </div>
        </section>
      </aside>
    </div>

    <datalist id="gallery-id-list">
      {galleryIds.map((id) => <option value={id} />)}
    </datalist>
  </section>
</BaseLayout>

<script is:inline>
  const editorRoot = document.querySelector(".journal-editor");
  const cloudinaryBase = editorRoot.dataset.cloudinaryBase;
  const fields = {
    template: document.getElementById("template"),
    date: document.getElementById("date"),
    title: document.getElementById("title"),
    slug: document.getElementById("slug"),
    filename: document.getElementById("filename"),
    permalink: document.getElementById("permalink"),
    urlStatus: document.getElementById("url-status"),
    ogDescription: document.getElementById("og-description"),
    thumbnail: document.getElementById("thumbnail"),
    thumbnailAlt: document.getElementById("thumbnail-alt"),
    thumbnailFit: document.getElementById("thumbnail-fit"),
    thumbnailPosition: document.getElementById("thumbnail-position"),
    ogImage: document.getElementById("og-image"),
    draft: document.getElementById("draft"),
    mediaStatus: document.getElementById("media-status"),
    tags: document.getElementById("tags"),
    featuredRelated: document.getElementById("featured-related"),
    thumbnailClass: document.getElementById("thumbnail-class"),
    useMath: document.getElementById("use-math"),
    body: document.getElementById("body"),
    cardLayout: document.getElementById("card-layout"),
    lightboxPreset: document.getElementById("lightbox-preset"),
    customLightbox: document.getElementById("custom-lightbox"),
    customLightboxRow: document.getElementById("custom-lightbox-row"),
    cardList: document.getElementById("card-list"),
    cardCount: document.getElementById("card-count"),
    articleInput: document.getElementById("article-input"),
    outputContent: document.getElementById("output-content"),
    galleryOutput: document.getElementById("gallery-output"),
    preview: document.getElementById("preview"),
    checklist: document.getElementById("publish-checklist"),
    draftStatus: document.getElementById("draft-status")
  };

  const storageKey = "riddle-records:journal-editor-cms-draft";
  let isRestoringDraft = false;
  let saveTimer = null;
  let cards = [];

  const templates = {
    journal: {
      body: "# 見出し\n\nここに本文を書きます。\n",
      permalink: ({ date }) => `/journal/${date}/`,
      filename: ({ date, slug }) => slug ? `${date}-${slug}.md` : `${date}.md`
    },
    making: {
      body: "# 概要\n\n## 制作メモ\n\n## こだわり\n\n## 関連\n\n",
      permalink: ({ date, slug }) => {
        const [year, month, day] = date.split("-");
        return slug ? `/journal/${year}/${month}/${day}/${slug}/` : `/journal/${date}/`;
      },
      filename: ({ date, slug }) => slug ? `${date}-${slug}.md` : `${date}.md`
    },
    report: {
      body: "# 今月の報告\n\n## やったこと\n\n- \n\n## 見たもの・行った場所\n\n- \n\n## これから\n\n- \n",
      permalink: ({ date }) => `/journal/${date.slice(0, 7)}/`,
      filename: ({ date, slug }) => slug ? `${date}-${slug}.md` : `${date}.md`
    }
  };

  const defaultCard = () => ({
    caption: "",
    heading: "",
    cloudinaryId: "",
    description: "",
    categories: "",
    comparisonLabel: "",
    comparisonOrder: "",
    thumbnail: true,
    noGalleryButton: true,
    makingArticleUrl: ""
  });

  const splitList = (value) => value.split(",").map((item) => item.trim()).filter(Boolean);
  const slugify = (value) => value
    .trim()
    .toLowerCase()
    .replace(/\s+/g, "-")
    .replace(/[^a-z0-9_-]/g, "")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");
  const escapeHtml = (value = "") => value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
  const yamlString = (value) => `"${value.replace(/\\/g, "\\\\").replace(/"/g, '\\"')}"`;
  const yamlArray = (items) => `[${items.map(yamlString).join(", ")}]`;
  const tsString = (value) => `"${value.replace(/\\/g, "\\\\").replace(/"/g, '\\"')}"`;
  const formatPreviewDate = (value) => {
    if (!value) return "";
    const [year, month, day] = value.split("-");
    return `${year}年${month}月${day}日`;
  };
  const applyInlineMarkdown = (value) => escapeHtml(value)
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');

  function getGeneratedPermalink() {
    const date = fields.date.value;
    if (!date) return "";
    const slug = slugify(fields.slug.value);
    return templates[fields.template.value].permalink({ date, slug });
  }

  function normalizePermalink(value) {
    return value.trim().replace(/\/+$/, "");
  }

  function hasPermalinkOverride() {
    const current = fields.permalink.value.trim();
    const generated = getGeneratedPermalink();
    return Boolean(current && generated && normalizePermalink(current) !== normalizePermalink(generated));
  }

  function resolveEditorImage(value, transform = "w_400,h_400,c_fill,q_auto,f_auto") {
    const image = value.trim();
    if (!image) {
      return { kind: "empty", label: "未入力", url: "" };
    }

    if (/^https?:\/\//.test(image)) {
      return { kind: "url", label: "URL", url: image };
    }

    if (image.startsWith("/")) {
      return { kind: "local", label: "ローカルパス", url: image };
    }

    return {
      kind: "cloudinary",
      label: "Cloudinary ID",
      url: `${cloudinaryBase}/${transform}/v1/${image}`
    };
  }

  function getLightboxGroup() {
    if (fields.lightboxPreset.value === "custom") {
      return fields.customLightbox.value.trim() || "Journal";
    }
    return fields.lightboxPreset.value;
  }

  function buildFrontmatter() {
    const lines = ["---"];
    const title = fields.title.value.trim() || "Untitled";
    const date = fields.date.value;
    const tags = splitList(fields.tags.value);
    const related = splitList(fields.featuredRelated.value);
    const slug = slugify(fields.slug.value);

    lines.push(`title: ${yamlString(title)}`);
    if (date) lines.push(`date: ${date}`);
    lines.push(`type: ${yamlString(fields.template.value)}`);
    if (slug) lines.push(`slug: ${yamlString(slug)}`);
    if (fields.ogDescription.value.trim()) lines.push(`description: ${yamlString(fields.ogDescription.value.trim())}`);
    if (tags.length > 0) lines.push(`tags: ${yamlArray(tags)}`);
    if (fields.draft.checked) lines.push("draft: true");
    if (fields.thumbnail.value.trim()) lines.push(`thumbnail: ${yamlString(fields.thumbnail.value.trim())}`);
    if (fields.thumbnailAlt.value.trim()) lines.push(`thumbnail_alt: ${yamlString(fields.thumbnailAlt.value.trim())}`);
    if (fields.thumbnailFit.value.trim()) lines.push(`thumbnail_fit: ${yamlString(fields.thumbnailFit.value.trim())}`);
    if (fields.thumbnailPosition.value.trim()) lines.push(`thumbnail_position: ${yamlString(fields.thumbnailPosition.value.trim())}`);
    if (fields.ogImage.value.trim()) lines.push(`og_image: ${yamlString(fields.ogImage.value.trim())}`);
    if (related.length > 0) lines.push(`featured_related: ${yamlArray(related)}`);
    if (fields.useMath.checked) lines.push("use_math: true");
    if (fields.thumbnailClass.value.trim()) lines.push(`thumbnail_class: ${yamlString(fields.thumbnailClass.value.trim())}`);
    if (hasPermalinkOverride()) lines.push(`permalink: ${fields.permalink.value.trim()}`);
    lines.push("---");
    return lines.join("\n");
  }

  function getBodyMarkdown() {
    return `${fields.body.value.trimEnd()}\n`;
  }

  function renderMarkdown(markdown) {
    const lines = markdown.replace(/\r\n/g, "\n").split("\n");
    const html = [];
    let inList = false;
    let inOrderedList = false;
    let inCode = false;
    let codeLines = [];

    const closeList = () => {
      if (inList) {
        html.push("</ul>");
        inList = false;
      }
      if (inOrderedList) {
        html.push("</ol>");
        inOrderedList = false;
      }
    };

    lines.forEach((line) => {
      if (line.startsWith("```")) {
        if (inCode) {
          html.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`);
          codeLines = [];
          inCode = false;
        } else {
          closeList();
          inCode = true;
        }
        return;
      }

      if (inCode) {
        codeLines.push(line);
        return;
      }

      if (!line.trim()) {
        closeList();
        return;
      }

      const heading = line.match(/^(#{1,4})\s+(.+)$/);
      if (heading) {
        closeList();
        const level = heading[1].length;
        html.push(`<h${level}>${applyInlineMarkdown(heading[2])}</h${level}>`);
        return;
      }

      const listItem = line.match(/^[-*]\s+(.+)$/);
      if (listItem) {
        if (inOrderedList) {
          html.push("</ol>");
          inOrderedList = false;
        }
        if (!inList) {
          html.push("<ul>");
          inList = true;
        }
        html.push(`<li>${applyInlineMarkdown(listItem[1])}</li>`);
        return;
      }

      const orderedListItem = line.match(/^\d+\.\s+(.+)$/);
      if (orderedListItem) {
        if (inList) {
          html.push("</ul>");
          inList = false;
        }
        if (!inOrderedList) {
          html.push("<ol>");
          inOrderedList = true;
        }
        html.push(`<li>${applyInlineMarkdown(orderedListItem[1])}</li>`);
        return;
      }

      const quote = line.match(/^>\s?(.+)$/);
      if (quote) {
        closeList();
        html.push(`<blockquote><p>${applyInlineMarkdown(quote[1])}</p></blockquote>`);
        return;
      }

      if (line.trim().startsWith("<")) {
        closeList();
        html.push(line);
        return;
      }

      closeList();
      html.push(`<p>${applyInlineMarkdown(line)}</p>`);
    });

    closeList();
    return html.join("\n");
  }

  function renderPreview(markdown) {
    const previewDate = formatPreviewDate(fields.date.value);
    const title = fields.title.value.trim() || "Untitled";
    const summary = fields.ogDescription.value.trim();
    const bodyHtml = renderMarkdown(markdown);

    fields.preview.innerHTML = `
      <header class="journal-hero preview-hero">
        ${previewDate ? `<p class="journal-date"><time datetime="${escapeHtml(fields.date.value)}">${escapeHtml(previewDate)}</time></p>` : ""}
        <h1 class="page_title">${escapeHtml(title)}</h1>
        ${summary ? `<p class="journal-summary">${applyInlineMarkdown(summary)}</p>` : ""}
      </header>
      <div class="post-content journal-content preview-content">
        ${bodyHtml}
      </div>
    `;
  }

  function syncDerivedFields(forcePermalink = false) {
    const slug = slugify(fields.slug.value);
    if (fields.slug.value && fields.slug.value !== slug) {
      fields.slug.value = slug;
    }
    const template = templates[fields.template.value];
    fields.filename.value = template.filename({ date: fields.date.value, slug });
    if (forcePermalink || !fields.permalink.dataset.touched) {
      fields.permalink.value = getGeneratedPermalink();
    }
  }

  function cleanCards() {
    return cards.filter((card) => card.cloudinaryId.trim());
  }

  function buildCardsHtml() {
    const activeCards = cleanCards();
    if (!activeCards.length) return "";
    const group = getLightboxGroup();

    if (fields.cardLayout.value === "making-comparison-grid") {
      const items = activeCards.map((card) => {
        const caption = card.caption || card.heading || "";
        const label = card.comparisonLabel || card.heading || caption;
        const blockClass = card.noGalleryButton ? " no-gallery-button" : "";
        return `  <div class="comparison-item${blockClass}">
    <a href="${cloudinaryBase}/w_1920,q_auto,f_auto/v1/${escapeHtml(card.cloudinaryId.trim())}" data-lightbox="${escapeHtml(group)}" data-title="${escapeHtml(caption)}">
      <img src="${cloudinaryBase}/w_300,h_300,c_fill,q_auto,f_auto/v1/${escapeHtml(card.cloudinaryId.trim())}" alt="${escapeHtml(caption)}">
    </a>${label ? `\n    <p class="comparison-label">${escapeHtml(label)}</p>` : ""}
  </div>`;
      }).join("\n");
      return `<div class="making-comparison-grid">\n${items}\n</div>`;
    }

    const items = activeCards.map((card) => {
      const caption = card.caption || card.heading || "";
      const heading = card.heading || card.caption || "";
      const blockClass = card.noGalleryButton ? " no-gallery-button" : "";
      return `  <div class="journal-card${blockClass}">
    <a href="${cloudinaryBase}/w_1920,q_auto,f_auto/v1/${escapeHtml(card.cloudinaryId.trim())}" data-lightbox="${escapeHtml(group)}" data-title="${escapeHtml(caption)}">
      <img src="${cloudinaryBase}/w_300,h_300,c_fill,q_auto,f_auto/v1/${escapeHtml(card.cloudinaryId.trim())}" alt="${escapeHtml(caption)}">
    </a>
    <div class="journal-card-info">
      <h4>${escapeHtml(heading)}</h4>
    </div>
  </div>`;
    }).join("\n");
    return `<div class="journal-card-grid">\n${items}\n</div>`;
  }

  function buildGalleryCode() {
    const activeCards = cleanCards();
    if (!activeCards.length) return "";
    const articleUrl = fields.permalink.value.trim();
    const date = fields.date.value;
    const comparisonGroup = slugify(fields.slug.value) || articleUrl.replace(/^\/+|\/+$/g, "").replace(/\//g, "-");

    return activeCards.map((card, index) => {
      const title = card.caption || card.heading || `Card ${index + 1}`;
      const description = card.description || title;
      const categories = splitList(card.categories);
      const lines = [
        "{",
        `  title: ${tsString(title)},`,
        `  date: ${tsString(date)},`,
        `  cloudinary_id: ${tsString(card.cloudinaryId.trim())},`,
        `  description: ${tsString(description)},`,
        `  categories: [${categories.map(tsString).join(", ")}],`,
        `  article_url: ${tsString(articleUrl)},`
      ];
      if (card.makingArticleUrl.trim()) lines.push(`  making_article_url: ${tsString(card.makingArticleUrl.trim())},`);
      lines.push(`  thumbnail: ${card.thumbnail ? "true" : "false"},`);
      if (fields.cardLayout.value === "making-comparison-grid") {
        lines.push(`  comparison_group: ${tsString(comparisonGroup)},`);
        if (card.comparisonLabel || card.heading) lines.push(`  comparison_label: ${tsString(card.comparisonLabel || card.heading)},`);
        if (card.comparisonOrder) lines.push(`  comparison_order: ${Number(card.comparisonOrder)},`);
      }
      lines.push("}");
      return lines.join("\n");
    }).join(",\n");
  }

  function renderChecklist() {
    const items = [
      {
        label: fields.title.value.trim() ? "title が入っています" : "title が空です",
        status: fields.title.value.trim() ? "ok" : "warn"
      },
      {
        label: fields.date.value ? "date が入っています" : "date が空です",
        status: fields.date.value ? "ok" : "warn"
      },
      {
        label: fields.ogDescription.value.trim() ? "description が入っています" : "description が空です",
        status: fields.ogDescription.value.trim() ? "ok" : "warn"
      },
      {
        label: fields.template.value === "making" && !fields.slug.value.trim() ? "making では slug の入力を推奨します" : "slug 条件は問題ありません",
        status: fields.template.value === "making" && !fields.slug.value.trim() ? "warn" : "ok"
      },
      {
        label: fields.thumbnail.value.trim() && !fields.thumbnailAlt.value.trim() ? "thumbnail があるため thumbnail_alt を入れてください" : "thumbnail_alt 条件は問題ありません",
        status: fields.thumbnail.value.trim() && !fields.thumbnailAlt.value.trim() ? "warn" : "ok"
      },
      {
        label: hasPermalinkOverride() ? "permalink override 中です" : "permalink は自動生成URLです",
        status: hasPermalinkOverride() ? "info" : "ok"
      }
    ];

    fields.checklist.innerHTML = items.map((item) => `
      <li class="is-${item.status}">
        <span>${item.status === "ok" ? "OK" : item.status === "warn" ? "警告" : "情報"}</span>
        ${escapeHtml(item.label)}
      </li>
    `).join("");
  }

  function renderUrlStatus() {
    const generated = getGeneratedPermalink();
    const current = fields.permalink.value.trim();
    const override = hasPermalinkOverride();
    fields.urlStatus.innerHTML = `
      <p><strong>自動生成URL</strong><code>${escapeHtml(generated || "日付を入力してください")}</code></p>
      ${override ? `<p><strong>override URL</strong><code>${escapeHtml(current)}</code></p>` : ""}
      <p class="${override ? "status-info" : "status-ok"}">${override ? "permalink override 中です。frontmatter に permalink を出力します。" : "自動生成URLを使用します。frontmatter に permalink は出力しません。"}</p>
    `;
  }

  function renderMediaStatus() {
    const thumbnail = resolveEditorImage(fields.thumbnail.value);
    const ogImage = resolveEditorImage(fields.ogImage.value, "w_1200,h_630,c_fill,q_auto,f_auto");
    const renderItem = (title, item) => `
      <div class="media-resolve-item">
        <div>
          <strong>${escapeHtml(title)}</strong>
          <p>${escapeHtml(item.label)}</p>
          ${item.url ? `<code>${escapeHtml(item.url)}</code>` : ""}
        </div>
        ${item.url ? `<img src="${escapeHtml(item.url)}" alt="${escapeHtml(title)} preview" loading="lazy" />` : ""}
      </div>
    `;

    fields.mediaStatus.innerHTML = `
      ${renderItem("thumbnail", thumbnail)}
      ${renderItem("og_image", ogImage)}
    `;
  }

  function updateCardCount() {
    fields.cardCount.textContent = `${cleanCards().length} cards`;
  }

  function renderCards() {
    updateCardCount();
    fields.cardList.innerHTML = cards.map((card, index) => `
      <article class="media-card" data-card-index="${index}">
        <div class="media-card-header">
          <strong>Card ${index + 1}</strong>
          <button type="button" data-card-action="remove" data-index="${index}">削除</button>
        </div>
        <label>
          <span>Cloudinary ID</span>
          <input type="text" data-card-field="cloudinaryId" data-index="${index}" list="gallery-id-list" value="${escapeHtml(card.cloudinaryId)}" placeholder="example_abcd12.jpg" />
        </label>
        <div class="field-row">
          <label>
            <span>キャプション</span>
            <input type="text" data-card-field="caption" data-index="${index}" value="${escapeHtml(card.caption)}" placeholder="画像の説明" />
          </label>
          <label>
            <span>見出し</span>
            <input type="text" data-card-field="heading" data-index="${index}" value="${escapeHtml(card.heading)}" placeholder="カード内見出し" />
          </label>
        </div>
        <label>
          <span>description (Gallery用)</span>
          <input type="text" data-card-field="description" data-index="${index}" value="${escapeHtml(card.description)}" placeholder="作品説明" />
        </label>
        <div class="field-row">
          <label>
            <span>categories (カンマ区切り)</span>
            <input type="text" data-card-field="categories" data-index="${index}" value="${escapeHtml(card.categories)}" placeholder="3DCG, Illustration" />
          </label>
          <label>
            <span>making_article_url</span>
            <input type="text" data-card-field="makingArticleUrl" data-index="${index}" value="${escapeHtml(card.makingArticleUrl)}" placeholder="/journal/2026/01/30/dunes-making/" />
          </label>
        </div>
        <div class="field-row">
          <label>
            <span>comparison_label</span>
            <input type="text" data-card-field="comparisonLabel" data-index="${index}" value="${escapeHtml(card.comparisonLabel)}" />
          </label>
          <label>
            <span>comparison_order</span>
            <input type="number" data-card-field="comparisonOrder" data-index="${index}" value="${escapeHtml(card.comparisonOrder)}" />
          </label>
        </div>
        <div class="switch-row">
          <label class="checkbox-field">
            <input type="checkbox" data-card-field="thumbnail" data-index="${index}" ${card.thumbnail ? "checked" : ""} />
            <span>サムネイル対象</span>
          </label>
          <label class="checkbox-field">
            <input type="checkbox" data-card-field="noGalleryButton" data-index="${index}" ${card.noGalleryButton ? "checked" : ""} />
            <span>ギャラリーボタン非表示</span>
          </label>
        </div>
      </article>
    `).join("");
  }

  function generate() {
    syncDerivedFields(false);
    fields.customLightboxRow.hidden = fields.lightboxPreset.value !== "custom";
    const markdown = `${buildFrontmatter()}\n\n${getBodyMarkdown()}`;
    fields.outputContent.value = markdown;
    fields.galleryOutput.value = buildGalleryCode();
    renderPreview(fields.body.value);
    renderChecklist();
    renderUrlStatus();
    renderMediaStatus();
    updateCardCount();
    saveDraft();
  }

  function insertAtCursor(textarea, text) {
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    textarea.value = `${textarea.value.slice(0, start)}${text}${textarea.value.slice(end)}`;
    textarea.selectionStart = textarea.selectionEnd = start + text.length;
    textarea.focus();
  }

  async function copyText(text, message) {
    await navigator.clipboard.writeText(text);
    setDraftStatus(message);
  }

  function downloadOutput() {
    const blob = new Blob([fields.outputContent.value], { type: "text/markdown;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = fields.filename.value || "journal.md";
    document.body.append(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
    setDraftStatus("Markdownをダウンロードしました");
  }

  function getDraftData() {
    return {
      template: fields.template.value,
      date: fields.date.value,
      title: fields.title.value,
      slug: fields.slug.value,
      permalink: fields.permalink.value,
      permalinkTouched: fields.permalink.dataset.touched === "true",
      ogDescription: fields.ogDescription.value,
      thumbnail: fields.thumbnail.value,
      thumbnailAlt: fields.thumbnailAlt.value,
      thumbnailFit: fields.thumbnailFit.value,
      thumbnailPosition: fields.thumbnailPosition.value,
      ogImage: fields.ogImage.value,
      draft: fields.draft.checked,
      tags: fields.tags.value,
      featuredRelated: fields.featuredRelated.value,
      thumbnailClass: fields.thumbnailClass.value,
      useMath: fields.useMath.checked,
      body: fields.body.value,
      cardLayout: fields.cardLayout.value,
      lightboxPreset: fields.lightboxPreset.value,
      customLightbox: fields.customLightbox.value,
      cards
    };
  }

  function setDraftData(data) {
    if (!data || typeof data !== "object") return false;
    fields.template.value = data.template && templates[data.template] ? data.template : "journal";
    fields.date.value = data.date || fields.date.value;
    fields.title.value = data.title || "";
    fields.slug.value = data.slug || "";
    fields.permalink.value = data.permalink || "";
    fields.permalink.dataset.touched = data.permalinkTouched ? "true" : "";
    fields.ogDescription.value = data.ogDescription || "";
    fields.thumbnail.value = data.thumbnail || "";
    fields.thumbnailAlt.value = data.thumbnailAlt || "";
    fields.thumbnailFit.value = data.thumbnailFit || "";
    fields.thumbnailPosition.value = data.thumbnailPosition || "";
    fields.ogImage.value = data.ogImage || data.image || "";
    fields.draft.checked = data.draft === undefined ? true : Boolean(data.draft);
    fields.tags.value = data.tags || "";
    fields.featuredRelated.value = data.featuredRelated || "";
    fields.thumbnailClass.value = data.thumbnailClass || "";
    fields.useMath.checked = Boolean(data.useMath);
    fields.body.value = data.body || templates[fields.template.value].body;
    fields.cardLayout.value = data.cardLayout || "journal-card-grid";
    fields.lightboxPreset.value = data.lightboxPreset || "Journal";
    fields.customLightbox.value = data.customLightbox || "";
    cards = Array.isArray(data.cards) && data.cards.length ? data.cards : [defaultCard()];
    return true;
  }

  function saveDraft() {
    if (isRestoringDraft) return;
    setDraftStatus("保存中...");
    window.clearTimeout(saveTimer);
    saveTimer = window.setTimeout(() => {
      localStorage.setItem(storageKey, JSON.stringify(getDraftData()));
      setDraftStatus("下書きを自動保存しました");
    }, 260);
  }

  function restoreDraft() {
    const raw = localStorage.getItem(storageKey);
    if (!raw) return false;

    try {
      isRestoringDraft = true;
      const restored = setDraftData(JSON.parse(raw));
      isRestoringDraft = false;
      if (restored) {
        renderCards();
        generate();
        setDraftStatus("保存済みの下書きを復元しました");
      }
      return restored;
    } catch {
      isRestoringDraft = false;
      localStorage.removeItem(storageKey);
      return false;
    }
  }

  function clearDraft() {
    localStorage.removeItem(storageKey);
    setDraftStatus("保存済みの下書きを削除しました");
  }

  function setDraftStatus(message) {
    fields.draftStatus.textContent = message;
  }

  function resetForm() {
    fields.title.value = "";
    fields.slug.value = "";
    fields.permalink.dataset.touched = "";
    fields.ogDescription.value = "";
    fields.thumbnail.value = "";
    fields.thumbnailAlt.value = "";
    fields.thumbnailFit.value = "";
    fields.thumbnailPosition.value = "";
    fields.ogImage.value = "";
    fields.draft.checked = true;
    fields.tags.value = "";
    fields.featuredRelated.value = "";
    fields.thumbnailClass.value = "";
    fields.useMath.checked = false;
    fields.cardLayout.value = "journal-card-grid";
    fields.lightboxPreset.value = "Journal";
    fields.customLightbox.value = "";
    fields.articleInput.value = "";
    cards = [defaultCard()];
    fields.body.value = templates[fields.template.value].body;
    syncDerivedFields(true);
    renderCards();
    generate();
    setDraftStatus("初期化しました");
  }

  function extractCloudinaryId(url) {
    if (!url) return "";
    const match = url.match(/\/image\/upload\/(?:[^/]*\/)*([^?/\s]+)(?:\?.*)?$/);
    return match ? match[1] : url.trim();
  }

  function analyzeArticle() {
    const raw = fields.articleInput.value;
    if (!raw.trim()) {
      setDraftStatus("解析する本文を貼り付けてください");
      return;
    }

    const doc = new DOMParser().parseFromString(raw, "text/html");
    const nodes = Array.from(doc.querySelectorAll(".journal-card, .comparison-item"));
    if (!nodes.length) {
      setDraftStatus("カード要素が見つかりませんでした");
      return;
    }

    const parsed = nodes.map((node, index) => {
      const anchor = node.querySelector("a");
      const img = node.querySelector("img");
      const caption = (anchor && anchor.getAttribute("data-title")) || (img && img.alt) || "";
      const labelNode = node.querySelector("h4") || node.querySelector(".comparison-label");
      const lightbox = anchor ? anchor.getAttribute("data-lightbox") || "" : "";
      return {
        ...defaultCard(),
        caption,
        heading: labelNode ? labelNode.textContent.trim() : caption,
        cloudinaryId: extractCloudinaryId(anchor ? anchor.href : img ? img.src : ""),
        comparisonLabel: labelNode ? labelNode.textContent.trim() : caption,
        comparisonOrder: index + 1,
        noGalleryButton: node.classList.contains("no-gallery-button")
      };
    }).filter((card) => card.cloudinaryId);

    if (!parsed.length) {
      setDraftStatus("Cloudinary IDを持つカードが見つかりませんでした");
      return;
    }

    const firstCustomLightbox = nodes
      .map((node) => node.querySelector("a")?.getAttribute("data-lightbox") || "")
      .find((group) => group && !["Journal", "gallery", "making-comparison"].includes(group));
    const firstPresetLightbox = nodes
      .map((node) => node.querySelector("a")?.getAttribute("data-lightbox") || "")
      .find((group) => ["Journal", "gallery", "making-comparison"].includes(group));

    if (firstCustomLightbox) {
      fields.lightboxPreset.value = "custom";
      fields.customLightbox.value = firstCustomLightbox;
    } else if (firstPresetLightbox) {
      fields.lightboxPreset.value = firstPresetLightbox;
    }

    if (nodes.some((node) => node.classList.contains("comparison-item"))) {
      fields.cardLayout.value = "making-comparison-grid";
    }

    cards = parsed;
    renderCards();
    generate();
    setDraftStatus("本文からカードを抽出しました");
  }

  document.querySelectorAll("input, textarea, select").forEach((field) => {
    field.addEventListener("input", generate);
    field.addEventListener("change", generate);
  });

  fields.permalink.addEventListener("input", () => {
    fields.permalink.dataset.touched = "true";
  });

  fields.template.addEventListener("change", () => {
    fields.body.value = templates[fields.template.value].body;
    fields.permalink.dataset.touched = "";
    syncDerivedFields(true);
    generate();
  });

  fields.cardList.addEventListener("input", (event) => {
    const field = event.target.dataset.cardField;
    if (!field) return;
    const index = Number(event.target.dataset.index);
    cards[index][field] = event.target.type === "checkbox" ? event.target.checked : event.target.value;
    generate();
  });

  fields.cardList.addEventListener("change", (event) => {
    const field = event.target.dataset.cardField;
    if (!field) return;
    const index = Number(event.target.dataset.index);
    cards[index][field] = event.target.type === "checkbox" ? event.target.checked : event.target.value;
    generate();
  });

  fields.cardList.addEventListener("click", (event) => {
    const action = event.target.dataset.cardAction;
    if (action !== "remove") return;
    const index = Number(event.target.dataset.index);
    if (cards.length === 1) {
      cards[0] = defaultCard();
    } else {
      cards.splice(index, 1);
    }
    renderCards();
    generate();
  });

  document.querySelectorAll(".tab-button").forEach((button) => {
    button.addEventListener("click", () => {
      document.querySelectorAll(".tab-button").forEach((item) => item.classList.toggle("is-active", item === button));
      document.querySelectorAll(".tab-panel").forEach((panel) => panel.classList.toggle("is-active", panel.dataset.panel === button.dataset.tab));
    });
  });

  document.querySelector("[data-action='add-card']").addEventListener("click", () => {
    cards.push(defaultCard());
    renderCards();
    generate();
  });
  document.querySelector("[data-action='insert-cards']").addEventListener("click", () => {
    const html = buildCardsHtml();
    if (!html) {
      setDraftStatus("挿入するカードがありません");
      return;
    }
    insertAtCursor(fields.body, `\n\n${html}\n\n`);
    generate();
  });
  document.querySelector("[data-action='append-featured']").addEventListener("click", () => {
    const items = splitList(fields.featuredRelated.value);
    cleanCards().forEach((card) => {
      const id = card.cloudinaryId.trim();
      if (id && !items.includes(id)) items.push(id);
    });
    fields.featuredRelated.value = items.join(", ");
    generate();
  });
  document.querySelector("[data-action='analyze-article']").addEventListener("click", analyzeArticle);
  document.querySelector("[data-action='reset-cards']").addEventListener("click", () => {
    cards = [defaultCard()];
    renderCards();
    generate();
    setDraftStatus("カードを初期化しました");
  });
  document.querySelector("[data-action='copy-content']").addEventListener("click", () => copyText(fields.outputContent.value, "記事全体をコピーしました"));
  document.querySelector("[data-action='copy-frontmatter']").addEventListener("click", () => copyText(buildFrontmatter(), "frontmatterをコピーしました"));
  document.querySelector("[data-action='copy-body']").addEventListener("click", () => copyText(getBodyMarkdown(), "本文をコピーしました"));
  document.querySelector("[data-action='copy-gallery']").addEventListener("click", () => copyText(fields.galleryOutput.value, "Galleryコードをコピーしました"));
  document.querySelector("[data-action='download-content']").addEventListener("click", downloadOutput);
  document.querySelector("[data-action='clear-draft']").addEventListener("click", clearDraft);
  document.querySelector("[data-action='reset-form']").addEventListener("click", resetForm);

  if (!restoreDraft()) {
    resetForm();
  }
</script>

<style>
