    transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  input:focus,
  textarea:focus,
  select:focus {
    border-color: rgba(22, 138, 115, 0.72);
    box-shadow: 0 0 0 3px rgba(22, 138, 115, 0.14);
    outline: none;
  }

  input[readonly],
  textarea[readonly] {
    background: #f8faf8;
    color: rgba(18, 32, 25, 0.82);
  }

  textarea {
    resize: vertical;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    line-height: 1.55;
  }

  .body-editor {
    min-height: 320px;
    max-height: 60vh;
    background: #fff;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    font-size: 0.92rem;
  }

  .article-analyzer {
    min-height: 170px;
  }

  .output-editor {
    min-height: 300px;
    font-size: 0.88rem;
  }

  .compact-output {
    min-height: 220px;
  }

  .checkbox-field {
    display: flex;
    min-height: 43px;
    align-items: center;
    gap: 0.5rem;
    padding: 0.68rem 0.75rem;
    border: 1px solid var(--editor-line);
    border-radius: 6px;
    background: var(--editor-panel-strong);
  }

  .checkbox-field input {
    width: auto;
    accent-color: var(--editor-accent);
  }

  .card-list {
    display: grid;
    gap: 0.8rem;
  }

  .media-card {
    padding: 1rem;
    border: 1px solid rgba(22, 138, 115, 0.18);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(22, 138, 115, 0.06), rgba(255, 255, 255, 0.76));
  }

  .media-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .utility-details {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--editor-line);
  }

  .utility-details summary {
    cursor: pointer;
    color: var(--editor-accent-dark);
    font-weight: 800;
  }

  .generated-url-panel,
  .media-resolve-panel {
    display: grid;
    gap: 0.55rem;
    margin-top: 0.2rem;
    margin-bottom: 0.8rem;
    padding: 0.75rem;
    border: 1px solid rgba(22, 138, 115, 0.18);
    border-radius: 8px;
    background: rgba(42, 220, 163, 0.07);
  }

  .generated-url-panel p {
    margin: 0;
  }

  .generated-url-panel code,
  .media-resolve-panel code {
    display: block;
    overflow-wrap: anywhere;
    margin-top: 0.25rem;
    font-size: 0.82rem;
  }

  .status-ok {
    color: var(--editor-accent-dark);
  }

  .status-info {
    color: #6c5520;
  }

