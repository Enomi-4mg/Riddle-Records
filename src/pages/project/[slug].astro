---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjectItems } from "../../utils/projects";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const href = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
const formatDate = (date) => date ? new Date(date).toLocaleDateString("ja-JP") : "";

export async function getStaticPaths() {
  const projects = await getProjectItems();
  return projects.map((project) => ({
    params: {
      slug: project.slug
    },
    props: {
      project
    }
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={project.title}
  description={project.description}
  ogTitle={project.title}
  ogDescription={project.description}
  ogType="article"
  ogImage={project.hero || undefined}
  ogImageAlt={project.title}
>
  <article class="project-detail journal-entry-animate">
    <a class="project-back-link" href={href("/project/")}>Project一覧へ戻る</a>

    <header class="project-detail-header">
      {project.status && <p class="project-kicker">{project.status}</p>}
      <h1 class="web_title">{project.title}</h1>
      {project.date && <time class="project-date" datetime={project.date}>{formatDate(project.date)}</time>}
      <p class="project-lead">{project.description}</p>
    </header>

    <div class={`project-hero${project.hero ? "" : " project-hero-fallback"}`}>
      {project.hero ? (
        <img src={project.hero} alt={`${project.title} preview`} />
      ) : (
        <span>{project.title}</span>
      )}
    </div>

    <section class="project-section">
      <h2 class="page_title">概要</h2>
      <p>{project.body || project.description}</p>
    </section>

    <section class="project-section">
      <h2 class="page_title">主な機能</h2>
      <ul class="project-feature-list">
        {project.features.map((feature) => <li>{feature}</li>)}
      </ul>
    </section>

    <section class="project-section">
      <h2 class="page_title">リンク</h2>
      <div class="project-tags" aria-label={`${project.title} tags`}>
        {project.tags.map((tag) => <span class="project-tag">{tag}</span>)}
      </div>
      <div class="project-actions">
        {project.links.map((link, index) => (
          <a href={link.url} class={`project-action${index === 0 ? " project-action-primary" : ""}`} target="_blank" rel="noopener noreferrer">{link.label}</a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
