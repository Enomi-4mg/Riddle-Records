---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base : `${base}/`;
const href = (path) => `${basePath}${path.replace(/^\/+/, "")}`;
const formatDate = (date) => new Date(date).toLocaleDateString("ja-JP");

export function getStaticPaths() {
  return projects.map((project) => ({
    params: {
      slug: project.slug
    },
    props: {
      project
    }
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={project.title}
  description={project.description}
  ogTitle={project.title}
  ogDescription={project.description}
  ogType="article"
  ogImage={project.heroImage || undefined}
  ogImageAlt={project.title}
>
  <article class="project-detail journal-entry-animate">
    <a class="project-back-link" href={href("/project/")}>Project一覧へ戻る</a>

    <header class="project-detail-header">
      <p class="project-kicker">{project.subtitle}</p>
      <h1 class="web_title">{project.title}</h1>
      <time class="project-date" datetime={project.date}>{formatDate(project.date)}</time>
      <p class="project-lead">{project.description}</p>
    </header>

    <div class={`project-hero${project.heroImage ? "" : " project-hero-fallback"}`}>
      {project.heroImage ? (
        <img src={project.heroImage} alt={`${project.title} preview`} />
      ) : (
        <span>{project.title}</span>
      )}
    </div>

    <section class="project-section">
      <h2 class="page_title">概要</h2>
      <p>{project.description}</p>
    </section>

    <section class="project-section">
      <h2 class="page_title">主な機能</h2>
      <ul class="project-feature-list">
        {project.features.map((feature) => <li>{feature}</li>)}
      </ul>
    </section>

    <section class="project-section">
      <h2 class="page_title">リンク</h2>
      <div class="project-tags" aria-label={`${project.title} tags`}>
        {project.tags.map((tag) => <span class="project-tag">{tag}</span>)}
      </div>
      <div class="project-actions">
        <a href={project.externalUrl} class="project-action project-action-primary" target="_blank" rel="noopener noreferrer">外部サイトを見る</a>
        {project.sourceUrl && (
          <a href={project.sourceUrl} class="project-action" target="_blank" rel="noopener noreferrer">GitHubを見る</a>
        )}
      </div>
    </section>
  </article>
</BaseLayout>
