{
  "name": "riddle-journal-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:yaml": "node scripts/test-yaml-frontmatter.mjs",
    "test:roundtrip:journal": "node scripts/roundtrip-journal.mjs",
    "test:roundtrip:songs": "node scripts/roundtrip-songs.mjs",
    "test:roundtrip:gallery": "node scripts/roundtrip-content-kind.mjs gallery",
    "test:roundtrip:projects": "node scripts/roundtrip-content-kind.mjs projects",
    "test:roundtrip": "npm run test:yaml && npm run test:roundtrip:journal && npm run test:roundtrip:songs && npm run test:roundtrip:gallery && npm run test:roundtrip:projects",
    "test:content": "npm run test:roundtrip",
    "test:roundtrip:write": "node scripts/roundtrip-journal.mjs --write-exported ./roundtrip-exported"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "marked": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
